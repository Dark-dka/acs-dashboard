# Server
PORT=3001

# JWT Secret (change in production!)
JWT_SECRET=change-me-in-production-acs-2026

# ACS API Gateway Base URL (local network)
ACS_BASE_URL=http://10.100.10.23:8080

# Service Account (operator) — read access + person/credential writes
ACS_SERVICE_ACCOUNT=crm_backend
ACS_SERVICE_SECRET=crm-secret-2026

# Service Account (admin) — door actions, deploy, device management
ACS_ADMIN_ACCOUNT=ops_console
ACS_ADMIN_SECRET=ops-secret-2026

# Fallback API Key (legacy)
ACS_API_KEY=dev-api-key-2026

# Default admin user (created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
